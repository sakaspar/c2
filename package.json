{
  "name": "tunisian-bnpl-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Production-structured Tunisian BNPL fintech platform with Next.js, NestJS, and a JSON data lake storage engine.",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @bnpl/api --filter @bnpl/web dev",
    "dev:api": "pnpm --filter @bnpl/api dev",
    "dev:web": "pnpm --filter @bnpl/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "seed": "pnpm --filter @bnpl/api seed",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
