{
  "name": "@bnpl/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "predev": "pnpm --filter @bnpl/shared build",
    "dev": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true});try{require('fs').rmSync('tsconfig.tsbuildinfo',{force:true})}catch{}\" && nest start --watch",
    "prebuild": "pnpm --filter @bnpl/shared build",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true});try{require('fs').rmSync('tsconfig.tsbuildinfo',{force:true})}catch{}\" && nest build",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/scripts/seed.ts",
    "test": "jest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.717.0",
    "@bnpl/shared": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/throttler": "^6.3.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.0.0",
    "nanoid": "^5.0.9",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/testing": "^10.4.15",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^9.17.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
